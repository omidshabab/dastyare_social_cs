{
  "openapi": "3.0.0",
  "info": {
    "title": "Dastyare Social — CS",
    "version": "1.0.0",
    "description": "REST API for Dastyare Social Creator Studio. Manage posts (threads, shorts, media) and stories. Supports JSON and multipart uploads, reactions, views, and likes. Authentication via Better Auth (bearer token or API key). See /llms.txt for LLM-oriented documentation."
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "insertPostsSchema": {
        "type": "object"
      },
      "insertReactionsSchema": {
        "type": "object",
        "properties": {
          "postId": {
            "type": "string"
          },
          "emoji": {
            "type": "string"
          },
          "count": {
            "type": "integer"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        },
        "required": [
          "postId",
          "emoji"
        ]
      },
      "insertStoriesSchema": {
        "type": "object"
      },
      "patchPostsSchema": {
        "type": "object"
      },
      "patchStoriesSchema": {
        "type": "object"
      },
      "postBatchViewInput": {
        "type": "object",
        "properties": {
          "ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1
          }
        },
        "required": [
          "ids"
        ]
      },
      "postCreateInput": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "postIdInput": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "id"
        ]
      },
      "postListInput": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer",
            "exclusiveMinimum": true,
            "minimum": 0
          },
          "limit": {
            "type": "integer",
            "exclusiveMinimum": true,
            "maximum": 100,
            "minimum": 0
          },
          "search": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "list",
              "shorts"
            ]
          }
        }
      },
      "PostParams": {
        "type": "object",
        "properties": {
          "post_id": {
            "type": "string"
          }
        },
        "required": [
          "post_id"
        ]
      },
      "postReactionInput": {
        "type": "object",
        "properties": {
          "postId": {
            "type": "string",
            "minLength": 1
          },
          "emoji": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "postId",
          "emoji"
        ]
      },
      "PostsCountResponse": {
        "type": "object",
        "properties": {
          "total": {
            "type": "number"
          }
        },
        "required": [
          "total"
        ]
      },
      "PostsListResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {}
          },
          "total": {
            "type": "number"
          },
          "hasMore": {
            "type": "boolean"
          },
          "page": {
            "type": "number"
          },
          "limit": {
            "type": "number"
          }
        },
        "required": [
          "items",
          "total",
          "hasMore",
          "page",
          "limit"
        ]
      },
      "PostsQueryParams": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "page": {
            "type": "string"
          },
          "limit": {
            "type": "string"
          },
          "search": {
            "type": "string"
          }
        }
      },
      "PostsResponse": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/PostsListResponse"
          },
          {
            "$ref": "#/components/schemas/PostsCountResponse"
          }
        ]
      },
      "PostSuccessResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          }
        },
        "required": [
          "success"
        ]
      },
      "PostWithReactionsSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "text",
              "image",
              "video",
              "voice",
              "file"
            ]
          },
          "content": {
            "type": "string",
            "nullable": true
          },
          "views": {
            "type": "string"
          },
          "pinnedAt": {
            "type": "string",
            "nullable": true
          },
          "media": {},
          "createdAt": {
            "type": "string",
            "nullable": true
          },
          "updatedAt": {
            "type": "string",
            "nullable": true
          },
          "reactions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "emoji": {
                  "type": "string"
                },
                "count": {
                  "type": "number"
                }
              },
              "required": [
                "emoji",
                "count"
              ]
            }
          }
        },
        "required": [
          "id",
          "type",
          "content",
          "views",
          "pinnedAt",
          "media",
          "createdAt",
          "updatedAt",
          "reactions"
        ]
      },
      "pushNotificationRequestSchema": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "body": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        }
      },
      "PushNotificationSendResponse": {
        "type": "object",
