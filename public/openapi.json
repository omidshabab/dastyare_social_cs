            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PushNotificationSendResponse"
                }
              }
            }
          }
        }
      }
    },
    "/stories": {
      "get": {
        "operationId": "get-stories",
        "summary": "List or count stories",
        "description": "Returns paginated stories. Use query type=count for total. Filter by kind=image or kind=video.",
        "tags": [
          "Stories"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "type",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "example"
          },
          {
            "in": "query",
            "name": "page",
