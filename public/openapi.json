{
  "openapi": "3.0.0",
  "info": {
    "title": "Dastyare Social — CS",
    "version": "1.0.0",
    "description": "REST API for Dastyare Social Creator Studio. Manage posts (threads, shorts, media) and stories. Supports JSON and multipart uploads, reactions, views, and likes. Authentication via Better Auth (bearer token or API key). See /llms.txt for LLM-oriented documentation."
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "patchPostsSchema": {
        "type": "object"
      },
      "patchStoriesSchema": {
        "type": "object"
      },
      "PostType": {
        "type": "string",
        "enum": [
          "text",
          "image",
          "video",
          "voice",
          "file"
        ]
      },
      "PostWithReactions": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "text",
              "image",
              "video",
              "voice",
              "file"
            ]
          },
          "content": {
            "type": "string",
            "nullable": true
          },
          "views": {
            "type": "string"
          },
          "pinnedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "media": {},
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "reactions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "emoji": {
                  "type": "string"
                },
                "count": {
                  "type": "number"
                }
              },
              "required": [
                "emoji",
                "count"
              ]
            }
          }
        },
        "required": [
          "id",
          "type",
          "content",
          "views",
          "pinnedAt",
          "media",
          "createdAt",
          "updatedAt",
          "reactions"
        ]
      },
      "StoryItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "image",
              "video"
            ]
          },
          "url": {
            "type": "string"
          },
          "duration": {
            "type": "number"
          },
          "likes": {
            "type": "number"
          },
          "views": {
            "type": "number"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "type",
          "url",
          "likes",
          "views",
          "createdAt"
        ]
      }
    },
    "responses": {}
  },
  "tags": [
    {
      "name": "Posts",
      "description": "Create, read, update, and delete posts. Supports text, image, video, voice, and file types. Includes reactions and view tracking."
    },
    {
      "name": "Stories",
      "description": "Ephemeral image and video stories with view and like counters."
    }
  ],
