            "type": "string"
          },
          "page": {
            "type": "string"
          },
          "limit": {
            "type": "string"
          },
          "search": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          }
        }
      },
      "StoriesResponse": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/StoriesListResponse"
          },
          {
            "$ref": "#/components/schemas/StoriesCountResponse"
          }
        ]
      },
      "storyIdInput": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
