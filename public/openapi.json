  "tags": [
    {
      "name": "Posts",
      "description": "Create, read, update, and delete posts. Supports text, image, video, voice, and file types. Includes reactions and view tracking."
    },
    {
      "name": "Stories",
      "description": "Ephemeral image and video stories with view and like counters."
    },
    {
      "name": "Push"
    }
  ],
  "paths": {
    "/posts": {
      "get": {
        "operationId": "get-posts",
        "summary": "List or count posts",
        "description": "Returns paginated posts with reactions. Use query type=count for total count, type=shorts for vertical videos (1080x1920). Default type=list.",
        "tags": [
          "Posts"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "type",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "example"
          },
          {
            "in": "query",
            "name": "page",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": 1
          },
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "example"
          },
          {
            "in": "query",
            "name": "search",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "example"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/200 PostsResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "post-posts",
        "summary": "Create a post or batch-increment views",
        "description": "Create a text post (JSON) or upload media (multipart/form-data with content and file). JSON body with action=batch-view and ids array increments views for multiple posts.",
        "tags": [
          "Posts"
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/201 PostWithReactionsSchema"
                }
              }
            }
          },
          "200 PostSuccessResponse": {
            "$ref": "#/components/responses/200 PostSuccessResponse"
          }
        }
      }
    },
    "/posts/{post_id}": {
      "get": {
        "operationId": "get-posts-{post_id}",
        "summary": "Get post by ID",
        "description": "Returns a single post with reactions.",
        "tags": [
          "Posts"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "post_id",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "123"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/200 PostWithReactionsSchema"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "post-posts-{post_id}",
        "summary": "Post actions",
        "description": "Perform actions on a post. action=reaction requires emoji string. action=view increments the view count.",
        "tags": [
          "Posts"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "post_id",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "123"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/201 PostWithReactionsSchema"
                }
              }
            }
          },
          "200 PostSuccessResponse": {
            "$ref": "#/components/responses/200 PostSuccessResponse"
          }
        }
      },
      "patch": {
        "operationId": "patch-posts-{post_id}",
        "summary": "Update post",
        "description": "Partial update of post fields (content, views, pinnedAt, media, type).",
        "tags": [
          "Posts"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "post_id",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "123"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/patchPostsSchema"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/200 PostWithReactionsSchema"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "delete-posts-{post_id}",
        "summary": "Delete post",
        "description": "Permanently deletes a post by ID.",
        "tags": [
          "Posts"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "post_id",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "123"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/200 PostSuccessResponse"
                }
              }
            }
          }
        }
      }
    },
    "/push": {
      "post": {
        "operationId": "post-push",
        "summary": "Save a browser push subscription",
        "description": "Register or update a push subscription for the current browser. Requires `endpoint` and `keys.p256dh` / `keys.auth`.",
        "tags": [
          "Push"
        ],
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/pushSubscriptionRequestSchema"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PushSubscriptionResponse"
                }
              }
            }
          }
        }
      }
    },
    "/push/send": {
      "post": {
        "operationId": "post-push-send",
        "summary": "Send browser push notifications to active subscribers",
        "description": "Broadcast a web push notification to all active subscriptions. Requires API key auth.",
        "tags": [
          "Push"
        ],
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
