            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "example"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/200 StoriesResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "post-stories",
        "summary": "Create a story",
        "description": "Create a story with JSON body or multipart/form-data (type, file, views, likes, media). Types: image, video.",
        "tags": [
          "Stories"
        ],
        "parameters": [],
