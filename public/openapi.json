{
  "openapi": "3.0.0",
  "info": {
    "title": "Dastyare Social — CS",
    "version": "1.0.0",
    "description": "REST API for Dastyare Social Creator Studio. Manage posts (threads, shorts, media) and stories. Supports JSON and multipart uploads, reactions, views, and likes. Authentication via Better Auth (bearer token or API key). See /llms.txt for LLM-oriented documentation."
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "insertPostsSchema": {
        "type": "object"
      },
      "insertReactionsSchema": {
        "type": "object",
        "properties": {
          "postId": {
            "type": "string"
          },
          "emoji": {
            "type": "string"
          },
          "count": {
            "type": "integer"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        },
        "required": [
          "postId",
          "emoji"
        ]
      },
      "insertStoriesSchema": {
        "type": "object"
      },
      "MediaUploadResponse": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "key": {
            "type": "string"
          },
          "width": {
            "type": "number"
          },
          "height": {
            "type": "number"
          },
          "duration": {
            "type": "number"
          },
          "mimeType": {
            "type": "string"
          },
          "size": {
            "type": "number"
          }
        },
        "required": [
          "url",
          "key",
          "width",
          "height",
          "mimeType",
          "size"
        ]
      },
      "patchPostsSchema": {
        "type": "object"
      },
      "patchStoriesSchema": {
        "type": "object"
      },
      "postBatchViewInput": {
        "type": "object",
        "properties": {
          "ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1
          }
        },
        "required": [
          "ids"
        ]
      },
      "postCreateInput": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "postIdInput": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "id"
        ]
      },
      "postListInput": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer",
            "exclusiveMinimum": true,
            "minimum": 0
          },
          "limit": {
            "type": "integer",
            "exclusiveMinimum": true,
            "maximum": 100,
            "minimum": 0
          },
          "search": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "list",
              "shorts"
            ]
          }
        }
      },
      "PostParams": {
        "type": "object",
        "properties": {
          "post_id": {
            "type": "string"
          }
        },
        "required": [
          "post_id"
        ]
      },
      "postReactionInput": {
        "type": "object",
        "properties": {
          "postId": {
            "type": "string",
            "minLength": 1
          },
          "emoji": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "postId",
          "emoji"
        ]
      },
      "PostsCountResponse": {
        "type": "object",
        "properties": {
          "total": {
            "type": "number"
          }
        },
        "required": [
          "total"
        ]
      },
      "PostsListResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {}
          },
          "total": {
            "type": "number"
          },
          "hasMore": {
            "type": "boolean"
          },
          "page": {
            "type": "number"
          },
          "limit": {
            "type": "number"
          }
        },
        "required": [
          "items",
          "total",
          "hasMore",
          "page",
          "limit"
        ]
      },
      "PostsQueryParams": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "page": {
            "type": "string"
          },
          "limit": {
            "type": "string"
          },
          "search": {
            "type": "string"
          }
        }
      },
      "PostsResponse": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/PostsListResponse"
          },
          {
            "$ref": "#/components/schemas/PostsCountResponse"
          }
        ]
      },
      "PostSuccessResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          }
        },
        "required": [
          "success"
        ]
      },
      "PostWithReactionsSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "text",
              "image",
              "video",
              "voice",
              "file"
            ]
          },
          "content": {
            "type": "string",
            "nullable": true
          },
          "views": {
            "type": "string"
          },
          "pinnedAt": {
            "type": "string",
            "nullable": true
          },
          "media": {},
          "createdAt": {
            "type": "string",
            "nullable": true
          },
          "updatedAt": {
            "type": "string",
            "nullable": true
          },
          "reactions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "emoji": {
                  "type": "string"
                },
                "count": {
                  "type": "number"
                }
              },
              "required": [
                "emoji",
                "count"
              ]
            }
          }
        },
        "required": [
          "id",
          "type",
          "content",
          "views",
          "pinnedAt",
          "media",
          "createdAt",
          "updatedAt",
          "reactions"
        ]
      },
      "pushNotificationRequestSchema": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "body": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        }
      },
      "PushNotificationSendResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "sent": {
            "type": "number"
          },
          "failed": {
            "type": "number"
          }
        },
        "required": [
          "success",
          "sent",
          "failed"
        ]
      },
      "pushSubscriptionRequestSchema": {
        "type": "object",
        "properties": {
          "endpoint": {
            "type": "string"
          },
          "keys": {
            "type": "object",
            "properties": {
              "p256dh": {
                "type": "string"
              },
              "auth": {
                "type": "string"
              }
            },
            "required": [
              "p256dh",
              "auth"
            ]
          }
        },
        "required": [
          "endpoint",
          "keys"
        ]
      },
      "PushSubscriptionResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          }
        },
        "required": [
          "success"
        ]
      },
      "selectReactionsSchema": {
        "type": "object",
        "properties": {
          "postId": {
            "type": "string"
          },
          "emoji": {
            "type": "string"
          },
          "count": {
            "type": "integer"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        },
        "required": [
          "postId",
          "emoji",
          "count",
          "createdAt",
          "updatedAt"
        ]
      },
      "StoriesCountResponse": {
        "type": "object",
        "properties": {
          "total": {
            "type": "number"
          }
        },
        "required": [
          "total"
        ]
      },
      "StoriesListResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {}
          },
          "total": {
            "type": "number"
          },
          "hasMore": {
            "type": "boolean"
          },
          "page": {
            "type": "number"
          },
          "limit": {
            "type": "number"
          }
        },
        "required": [
          "items",
          "total",
          "page",
          "limit"
        ]
      },
      "StoriesQueryParams": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "page": {
            "type": "string"
          },
          "limit": {
            "type": "string"
          },
          "search": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          }
        }
      },
      "StoriesResponse": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/StoriesListResponse"
          },
          {
            "$ref": "#/components/schemas/StoriesCountResponse"
          }
        ]
      },
      "storyIdInput": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "id"
        ]
      },
      "StoryItemSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "image",
              "video"
            ]
          },
          "views": {
            "type": "string"
          },
          "likes": {
            "type": "string"
          },
          "media": {},
          "createdAt": {
            "type": "string",
            "nullable": true
          },
          "updatedAt": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "id",
          "type",
          "views",
          "likes",
          "media",
          "createdAt",
          "updatedAt"
        ]
      },
      "storyLikeInput": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "direction": {
            "type": "string",
            "enum": [
              "inc",
              "dec"
            ]
          }
        },
        "required": [
          "id",
          "direction"
        ]
      },
      "storyListInput": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer",
            "exclusiveMinimum": true,
            "minimum": 0
          },
          "limit": {
            "type": "integer",
            "exclusiveMinimum": true,
            "maximum": 100,
            "minimum": 0
          },
          "search": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "image",
              "video"
            ]
          }
        }
      },
      "StoryParams": {
        "type": "object",
        "properties": {
          "story_id": {
            "type": "string"
          }
        },
        "required": [
          "story_id"
        ]
      },
      "StorySuccessResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          }
        },
        "required": [
          "success"
        ]
      },
      "unsubscribeRequestSchema": {
        "type": "object",
        "properties": {
          "endpoint": {
            "type": "string"
          }
        },
        "required": [
          "endpoint"
        ]
      }
    },
    "responses": {}
  },
  "tags": [
    {
      "name": "Posts",
      "description": "Create, read, update, and delete posts. Supports text, image, video, voice, and file types. Includes reactions and view tracking."
    },
    {
      "name": "Stories",
      "description": "Ephemeral image and video stories with view and like counters."
    },
    {
      "name": "Auth"
    },
    {
      "name": "Media"
    },
    {
      "name": "Push"
    }
  ],
  "paths": {
    "/auth/{all}": {
      "get": {
        "operationId": "get-auth-{all}",
        "summary": "",
        "description": "",
        "tags": [
          "Auth"
        ],
        "parameters": [
          {
            "name": "all",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "example",
            "description": "Path parameter: all"
          }
        ],
        "responses": {}
      },
      "post": {
        "operationId": "post-auth-{all}",
        "summary": "",
        "description": "",
        "tags": [
          "Auth"
        ],
        "parameters": [
          {
            "name": "all",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "example",
            "description": "Path parameter: all"
          }
        ],
        "responses": {}
      }
    },
    "/media": {
      "post": {
        "operationId": "post-media",
        "summary": "Upload media to S3",
        "description": "Uploads media files (images, videos) to S3 storage with automatic dimension detection. Accepts multipart/form-data with files[] array. Returns array of uploaded media objects with URLs and dimensions.",
        "tags": [
          "Media"
        ],
        "parameters": [],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "properties": {
                  "file": {
                    "format": "binary",
                    "type": "string"
                  }
                },
                "required": [
                  "file"
                ],
                "type": "object"
              }
            }
          },
          "description": "Multipart form data containing a file upload.",
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MediaUploadResponse"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/posts": {
      "get": {
        "operationId": "get-posts",
        "summary": "List or count posts",
        "description": "Returns paginated posts with reactions. Use query type=count for total count, type=shorts for vertical videos (1080x1920). Default type=list.",
        "tags": [
          "Posts"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "type",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "example"
          },
          {
            "in": "query",
            "name": "page",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": 1
          },
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "example"
          },
          {
            "in": "query",
            "name": "search",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "example"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PostsResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "post-posts",
        "summary": "Create a post or batch-increment views",
        "description": "Create a text post (JSON) or upload media (multipart/form-data). Legacy: accepts content and file. New: accepts files[], urls[], types[], widths[], heights[], durations[] for multiple media. JSON body with action=batch-view and ids array increments views for multiple posts.",
        "tags": [
          "Posts"
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PostWithReactionsSchema"
                }
              }
            }
          },
          "PostSuccessResponse": {
            "$ref": "#/components/responses/PostSuccessResponse"
          }
        }
      }
    },
    "/posts/{post_id}": {
      "get": {
        "operationId": "get-posts-{post_id}",
        "summary": "Get post by ID",
        "description": "Returns a single post with reactions.",
        "tags": [
          "Posts"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "post_id",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "123"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PostWithReactionsSchema"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "post-posts-{post_id}",
        "summary": "Post actions",
        "description": "Perform actions on a post. action=reaction requires emoji string. action=view increments the view count.",
        "tags": [
          "Posts"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "post_id",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "123"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PostWithReactionsSchema"
                }
              }
            }
          },
          "PostSuccessResponse": {
            "$ref": "#/components/responses/PostSuccessResponse"
          }
        }
      },
      "patch": {
        "operationId": "patch-posts-{post_id}",
        "summary": "Update post",
        "description": "Partial update of post fields (content, views, pinnedAt, media, type).",
        "tags": [
          "Posts"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "post_id",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "123"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/patchPostsSchema"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PostWithReactionsSchema"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "delete-posts-{post_id}",
        "summary": "Delete post",
        "description": "Permanently deletes a post by ID.",
        "tags": [
          "Posts"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "post_id",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "123"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PostSuccessResponse"
                }
              }
            }
          }
        }
      }
    },
    "/push": {
      "post": {
        "operationId": "post-push",
        "summary": "Save a browser push subscription",
        "description": "Register or update a push subscription for the current browser. Requires `endpoint` and `keys.p256dh` / `keys.auth`.",
        "tags": [
          "Push"
        ],
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
