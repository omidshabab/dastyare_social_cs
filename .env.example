# PostgreSQL connection string.
# Example: postgresql://user:password@host:5432/db
DATABASE_URL="postgresql://user:password@localhost:6782/db"

# Admin account used by the bootstrap script.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-strong-password

# Shared API key used by external clients for protected API routes.
# Send it as: Authorization: Bearer <your-key>
# Generate with: openssl rand -hex 32
API_KEY=replace-with-a-strong-secret
API_KEY_RATE_LIMIT_MAX_REQUESTS=30
API_KEY_RATE_LIMIT_WINDOW_MS=60000

# Better Auth configuration.
# BETTER_AUTH_URL should be your app's public URL.
# BETTER_AUTH_SECRET should be a long random secret.
BETTER_AUTH_URL="https://your-domain.com"
BETTER_AUTH_SECRET="replace-with-a-long-random-secret"

# The bootstrap script will create or update this admin user using the values above.
# It also reads the configured app name/username from config/app.config.json.

S3_ENDPOINT=""
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME="dastyare-social-cs"
S3_FORCE_PATH_STYLE=true

NEXT_PUBLIC_ANIMATED_EMOJIES=false

DS_SH_URL=
DS_SH_API_KEY=

# PostHog analytics configuration
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN="replace-with-public-project-token"
POSTHOG_API_KEY="replace-with-server-api-key"

# PostHog notes:
# - `NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN` (dashboard name `project token`) is the
#   client-side public key used by `posthog-js` in the browser. Obtain it from
#   your PostHog Project → Setup → JavaScript snippet. This value is safe to
#   expose to browsers.
# - `NEXT_PUBLIC_POSTHOG_HOST` (dashboard name `host`) points to PostHog Cloud
#   or your self-hosted URL (for example, `https://us.i.posthog.com` or
#   `https://analytics.example.com`).
# - `POSTHOG_API_KEY` is the server-side secret (Personal API key or Project
#   Secret) used by `posthog-node` for server captures. Keep this value secret
#   and never commit it to source control.
# - Backwards compatibility: this project also accepts the legacy names
#   `NEXT_PUBLIC_POSTHOG_PROJECT_API_KEY` and `NEXT_PUBLIC_POSTHOG_API_HOST` for
#   browsers, and `POSTHOG_API_HOST` on the server.
# - After updating `.env`, restart the dev server or rebuild the app so the
#   environment variables are picked up.

# Production domain for SEO and metadata
NEXT_PUBLIC_APP_URL="http://localhost:8729"
NEXT_PUBLIC_WEBPUSH_PUBLIC_KEY=""
WEBPUSH_PRIVATE_KEY=""
WEBPUSH_SUBJECT="mailto:hey@omidshabab.com"

# Search Console helpers (disabled by default):
# Set NEXT_PUBLIC_ENABLE_SEARCH_CONSOLE=true to enable meta/file verification helpers.
NEXT_PUBLIC_ENABLE_SEARCH_CONSOLE=false

# When enabled, provide either a token or filename below.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION_FILE=
# Optional: exact HTML file content Google provided.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION_FILE_CONTENT=

# Control indexing globally. Default: indexing blocked unless explicitly enabled.
# Set to true in production when you are ready for search engines to index the site.
NEXT_PUBLIC_ALLOW_INDEXING=false

# Show internal nav links (default: hidden). Set true for admin previews.
NEXT_PUBLIC_SHOW_INTERNAL_NAV=false